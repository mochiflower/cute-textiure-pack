{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "Miniblox cute/kawaii entity Textures",
  "version": "1.3",
  "description": "makes the mobs look adorbs for the gurly girls",
  "author": "mochi_iris",
  "background": {"service_worker": "background.js"},
  "icons": {
    "128": "icon.png"
  },
  "permissions": [
   "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://miniblox.io/*",
    "https://miniblox.online/*",
    "https://miniblox.org/*",
    "https://raw.githubusercontent.com/*"
  ]
}
